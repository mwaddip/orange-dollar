# ECDSA private key for Bitcoin-level signing (generated via /api/cabal/generate-wallet, DO NOT EDIT MANUALLY)
ECDSA_PRIVATE_KEY=

# Passphrase to protect wallet generation (set before first start)
WALLET_PASSPHRASE=

# Combined ML-DSA-44 public key from DKG ceremony (1312-byte hex)
PERMAFROST_PUBLIC_KEY=

# Network name — must match a key in /etc/orange-dollar/config.json
OPNET_NETWORK=testnet

# Contract addresses and RPC URL are read from /etc/orange-dollar/config.json
# (falls back to shared/config.json in repo for local development)

PORT=3001
